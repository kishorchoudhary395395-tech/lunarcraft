{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information linked to Minecraft username.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "minecraftUsername": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "minecraftUsername", "role", "createdAt"]
    },
    "Ticket": {
      "title": "Support Ticket",
      "description": "A support ticket created by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "category": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "pending", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "category", "subject", "message", "status", "createdAt", "updatedAt"]
    },
    "Suggestion": {
      "title": "Server Suggestion",
      "description": "A suggestion for the server submitted by a player.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "votes": { "type": "integer" },
        "status": { "type": "string", "enum": ["under-review", "planned", "implemented"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "description", "votes", "status", "createdAt"]
    },
    "Product": {
      "title": "Store Product",
      "description": "A rank, item, or perk available in the store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "description": { "type": "string" },
        "category": { "type": "string", "enum": ["rank", "item", "perk"] },
        "image": { "type": "string" }
      },
      "required": ["id", "name", "price", "description", "category", "image"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles stored by their UID."
    },
    "/tickets/{ticketId}": {
      "schema": "Ticket",
      "description": "Support tickets."
    },
    "/suggestions/{suggestionId}": {
      "schema": "Suggestion",
      "description": "Server suggestions."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store products."
    }
  }
}
